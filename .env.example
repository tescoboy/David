# Auth tokens (comma-separated). If not set, auth is disabled (testing only).
AUTH_TOKENS=your-secret-token-here,another-token

# Publisher/agent identity
AGENT_NAME=My Sales Agent
PUBLISHER_DOMAIN=ads.mysite.com

# Optional: override products with custom JSON (array of Product objects)
# PRODUCTS_JSON=[{"product_id":"...","name":"..."}]
